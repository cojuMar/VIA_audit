# =============================================================================
#  Project Aegis 2026 — Environment Variables
#  Copy this file to .env and fill in your values.
#  The platform runs without an API key — AI features will use fallback mode.
# =============================================================================

# Anthropic API Key (optional — enables Claude AI features across all modules)
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=

# PostgreSQL (defaults match docker-compose.yml — change only if customising)
# POSTGRES_PASSWORD=aegis_dev_pw

# MinIO (defaults match docker-compose.yml)
# MINIO_ROOT_USER=aegis_minio
# MINIO_ROOT_PASSWORD=aegis_minio_dev_pw

# -----------------------------------------------------------------------------
#  Auth service — REQUIRED (Sprint 21)
# -----------------------------------------------------------------------------

# JWT signing secret. REQUIRED. Must be long and random in production.
# Generate with:  openssl rand -hex 32
JWT_SECRET=aegis_dev_jwt_secret_change_in_prod

# Deployment environment. Set to 'prod' in production — fail-closes on missing
# JWT_SECRET and rejects wildcard CORS.
ENV=dev

# Comma-separated list of allowed CORS origins. In dev, leave empty to use the
# localhost:5173-5185 defaults. In prod, set explicitly, e.g.:
# CORS_ORIGINS=https://hub.via.example.com,https://pbc.via.example.com
CORS_ORIGINS=

# If set to a tenant UUID, enables public POST /auth/register into that tenant
# with role forced to 'end_user'. Leave unset to disable self-registration.
SELF_REGISTRATION_TENANT=

# Seed demo users (admin@via.com etc.) on startup. Set to 'false' in prod.
SEED_DEMO_DATA=true

